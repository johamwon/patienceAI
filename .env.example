# ─── KnowS AI 医学证据检索 ──────────────────────────────────────────────────
KNOWS_BASE_URL=https://api.nullht.com/v1
KNOWS_API_KEY=  # 留空 = 匿名调用（限流 3 req/s），申请到 Key 后填入

# ─── 硅基流动 SiliconFlow LLM ──────────────────────────────────────────────
LLM_API_KEY=your-siliconflow-api-key-here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# 可选模型：Qwen/Qwen2.5-14B-Instruct / Qwen/Qwen2.5-72B-Instruct
#           THUDM/glm-4-9b-chat / internlm/internlm2_5-7b-chat

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
